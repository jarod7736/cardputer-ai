# Optional environment overrides. Secrets do NOT live here; they live in
# /etc/cardputer-proxy/secrets/ and are loaded via systemd LoadCredential=.
#
# Default listen is 127.0.0.1:8420. Set 0.0.0.0 to expose to Tailnet/WG,
# then firewall the port so it's only reachable on those interfaces.
#
# CARDPUTER_PROXY_LISTEN_HOST=0.0.0.0
# CARDPUTER_PROXY_LISTEN_PORT=8420
#
# Path to a TOML profile catalog; if unset, the built-in default profile
# (claude-opus → Anthropic) is used.
# CARDPUTER_PROXY_CONFIG_PATH=/etc/cardputer-proxy/config.toml
